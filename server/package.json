{
  "name": "quillapp-server",
  "version": "1.0.0",
  "description": "QuillApp collaboration server with session sharing and version history",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f postgres",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "setup": "docker compose up -d && sleep 3 && prisma migrate dev",
    "test": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "uuid": "^9.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "dompurify": "^3.0.8",
    "jsdom": "^24.0.0",
    "dotenv": "^16.4.1"
  },
  "devDependencies": {
    "prisma": "^5.9.1",
    "vitest": "^1.2.2",
    "supertest": "^6.3.4"
  }
}
